# Use a Supabase project dedicated to AstroMarriage (not shared with NRIRoute / other apps).
# Create a new org project, run `supabase/migrations/*.sql`, then paste URL + anon key here.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_ASTRO_PROJECT_REF.supabase.co

NEXT_PUBLIC_SUPABASE_ANON_KEY=your_publishable_anon_key

# Public site URL — used by OAuth/email redirects & metadata/sitemap/Robots
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-only bypass for admin automation — required for phone OTP sign-in & STREAM_ASTROLOGER_EMAIL practitioner lookup (bypasses RLS)
# Service role JWT only (Dashboard → Settings → API → service_role “Reveal”). Never use anon or sb_publishable_* here.
SUPABASE_SERVICE_ROLE_KEY=

# Google sign-in (OAuth with Google directly; app creates Supabase user via Admin API — not Supabase’s Google provider).
# In Google Cloud Console add authorized redirect: {origin}/auth/google/callback (e.g. http://localhost:3000/auth/google/callback)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# PostHog (https://posthog.com) — omit to disable analytics bootstrapping
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# GA4 Measurement ID (G-xxxx) — omit to disable GA scripts
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Stitch (https://stitch.withgoogle.com/settings) — optional design export tooling
STITCH_API_KEY=

# Razorpay Standard Checkout — optional (secret key server-only)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# Phone sign-in — OTP delivered via Zavu (use sender id from Zavu Dashboard)
ZAVUDEV_API_KEY=
ZAVU_SENDER_ID=

# Stream Chat — in-app messaging (server mints JWT; /dashboard/chat). Enables text + attachments + voice in composer.
NEXT_PUBLIC_STREAM_API_KEY=
STREAM_API_SECRET=
# Practitioner receives consultation DMs. Email → resolves to Supabase public.users.id (Stream user id). Requires SUPABASE_SERVICE_ROLE_KEY.
STREAM_ASTROLOGER_EMAIL=
# If set alone (no EMAIL), fixed Stream member id instead of UUID lookup — optional legacy placeholder:
# STREAM_ASTROLOGER_USER_ID=astrologer-support
# STREAM_ASTROLOGER_LEGACY_USER_IDS= astrologer-support (comma-separated) removed from consultation channels once the practitioner UUID is synced.
STREAM_ASTROLOGER_LEGACY_USER_IDS=
# Overrides Stream display name upsert for practitioner (defaults: profile full_name or site practitioner short name).
STREAM_ASTROLOGER_DISPLAY_NAME=Kavita Rao

# Admin mobile alerts when a NEW customer opens dashboard chat (Web Push standard). Omit to hide the enrolment chip in admin.
# Generate keys locally: `npx web-push generate-vapid-keys` → public → NEXT_PUBLIC_WEB_PUSH_PUBLIC_KEY ; private → WEB_PUSH_PRIVATE_KEY
# WEB_PUSH_CONTACT must be a mailto: or https: URL per the Web Push protocol (subscriber contact).
NEXT_PUBLIC_WEB_PUSH_PUBLIC_KEY=
WEB_PUSH_PRIVATE_KEY=
WEB_PUSH_CONTACT=mailto:you@example.com
