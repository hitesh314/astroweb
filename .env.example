# Use a Supabase project dedicated to AstroMarriage (not shared with NRIRoute / other apps).
# Create a new org project, run `supabase/migrations/*.sql`, then paste URL + anon key here.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_ASTRO_PROJECT_REF.supabase.co

NEXT_PUBLIC_SUPABASE_ANON_KEY=your_publishable_anon_key

# Public site URL — used by OAuth/email redirects & metadata/sitemap/Robots
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-only bypass for admin automation — required for WhatsApp OTP sign-in (service role bypasses OTP table RLS)
# Service role JWT only (Dashboard → Settings → API → service_role “Reveal”). Never use anon or sb_publishable_* here.
SUPABASE_SERVICE_ROLE_KEY=

# Google sign-in (OAuth with Google directly; app creates Supabase user via Admin API — not Supabase’s Google provider).
# In Google Cloud Console add authorized redirect: {origin}/auth/google/callback (e.g. http://localhost:3000/auth/google/callback)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# PostHog (https://posthog.com) — omit to disable analytics bootstrapping
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# GA4 Measurement ID (G-xxxx) — omit to disable GA scripts
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Stitch (https://stitch.withgoogle.com/settings) — optional design export tooling
STITCH_API_KEY=

# WhatsApp checkout — marriage reading & plan inquiries (+91 9358214529 by default).
#Digits only including country code, no + prefix.
NEXT_PUBLIC_WHATSAPP_PAY_NUMBER=919358214529

# Razorpay Standard Checkout — optional / disabled when using WhatsApp pay (secret key server-only)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# WhatsApp OTP sign-in via Zavu — required for OTP route (sender id becomes Zavu-Sender header)
ZAVUDEV_API_KEY=
ZAVU_SENDER_ID=
