# From Supabase Dashboard → Project Settings → API (never commit real keys)

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

NEXT_PUBLIC_SUPABASE_ANON_KEY=your_publishable_anon_key

# Public site URL — used by OAuth/email redirects & metadata/sitemap/Robots
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-only bypass for admin automation & guarded scripts (never expose to client)

SUPABASE_SERVICE_ROLE_KEY=

# PostHog (https://posthog.com) — omit to disable analytics bootstrapping
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# GA4 Measurement ID (G-xxxx) — omit to disable GA scripts
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Stitch (https://stitch.withgoogle.com/settings) — optional design export tooling
STITCH_API_KEY=
